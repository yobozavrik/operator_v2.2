# ============================================
# Graviton Production Hub — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# === REQUIRED: Supabase Connection ===
# Self-hosted Supabase instance URL (use https:// in production!)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-instance.example.com

# Supabase anon (public) key — safe for client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase service role key — SERVER-SIDE ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# === OPTIONAL: Telegram Notifications ===
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Chat ID to send order notifications to
TELEGRAM_CHAT_ID=

# === OPTIONAL: n8n Webhooks for Stock Updates ===
# n8n webhook URL for operator dashboard
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/operator

# n8n webhook URL for pizza stock updates
N8N_PIZZA_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/pizza1

# n8n webhook URL for Graviton order proxy (/api/graviton/submit-order)
N8N_GRAVITON_ORDER_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/graviton-order

# === OPTIONAL: Florida Scheduled Distribution (Resend) ===
# Secret checked by /api/florida/distribution/scheduled-run
CRON_SECRET=

# Shared defaults (used by routes that still read generic keys)
RESEND_API_KEY=

# Florida
FLORIDA_DISTRIBUTION_EMAIL_FROM=
FLORIDA_DISTRIBUTION_EMAIL_TO=

# Konditerka (schema-specific keys preferred)
KONDITERKA_CRON_SECRET=
KONDITERKA_RESEND_API_KEY=
KONDITERKA_DISTRIBUTION_EMAIL_FROM=
KONDITERKA_DISTRIBUTION_EMAIL_TO=

# Bulvar (schema-specific keys preferred)
BULVAR_CRON_SECRET=
BULVAR_RESEND_API_KEY=
BULVAR_DISTRIBUTION_EMAIL_FROM=
BULVAR_DISTRIBUTION_EMAIL_TO=

# === OPTIONAL: GLM-OCR (Supply Invoices) ===
# OpenAI-compatible chat/completions endpoint for GLM OCR
GLM_OCR_API_URL=
GLM_OCR_API_KEY=
GLM_OCR_MODEL=glm-4.1v-thinking-flash
GLM_OCR_CONFIDENCE_THRESHOLD=0.85

# === OPTIONAL: Security ===
# Enable strict audit mode (allowlist only for metadata keys)
# AUDIT_STRICT_MODE=true

# Strict CORS: comma-separated list of allowed origins (no trailing slash).
# Production MUST include your Vercel domain(s).
# Example: ALLOWED_ORIGINS=https://yourapp.vercel.app,https://www.yourdomain.com
# IMPORTANT: set this to "Production" environment only in Vercel dashboard.
ALLOWED_ORIGINS=

# Vercel Preview Deployment Protection bypass secret.
# Set in Vercel dashboard: Settings → Git → Deployment Protection → Bypass Secret.
# Used by automated CI checks that need to access preview deployments.
# IMPORTANT: set this to "Preview" environment only in Vercel dashboard.
VERCEL_AUTOMATION_BYPASS_SECRET=

# OpenRouter AI (for AI chat assistant — set to Production/Preview, NOT local preview of prod)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.5:free
OPENROUTER_FALLBACK_MODELS=openai/gpt-4o-mini,google/gemini-2.0-flash-001

# === OPTIONAL: Role Access (RBAC bootstrap) ===
# Comma-separated allowlist for full owner access.
# Used when user metadata role is not set yet.
OWNER_EMAILS=
OWNER_USER_IDS=


# TEMP: bootstrap role for local testing (remove after Supabase RBAC is enabled)
RBAC_DEFAULT_ROLE=

# === Rate Limiting (Upstash Redis) ===
# Required for distributed rate limiting across serverless instances.
# Create a free Redis database at https://console.upstash.com/
# Then copy the REST URL and token from the dashboard.
# Without these, rate limiting is DISABLED (fail-open) and a warning is logged.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token
