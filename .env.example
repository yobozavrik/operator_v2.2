# ============================================
# Graviton Production Hub — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# === REQUIRED: Supabase Connection ===
# Self-hosted Supabase instance URL (use https:// in production!)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-instance.example.com

# Supabase anon (public) key — safe for client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase service role key — SERVER-SIDE ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# === OPTIONAL: Telegram Notifications ===
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Chat ID to send order notifications to
TELEGRAM_CHAT_ID=

# === OPTIONAL: n8n Webhooks for Stock Updates ===
# n8n webhook URL for operator dashboard
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/operator

# n8n webhook URL for pizza stock updates
N8N_PIZZA_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/pizza1

# === OPTIONAL: Florida Scheduled Distribution (Resend) ===
# Secret checked by /api/florida/distribution/scheduled-run
CRON_SECRET=
FLORIDA_CRON_SECRET=

# Shared defaults (used by routes that still read generic keys)
RESEND_API_KEY=

# Florida
FLORIDA_RESEND_API_KEY=
FLORIDA_DISTRIBUTION_EMAIL_FROM=
FLORIDA_DISTRIBUTION_EMAIL_TO=

# Konditerka (schema-specific keys preferred)
KONDITERKA_CRON_SECRET=
KONDITERKA_RESEND_API_KEY=
KONDITERKA_DISTRIBUTION_EMAIL_FROM=
KONDITERKA_DISTRIBUTION_EMAIL_TO=

# Bulvar (schema-specific keys preferred)
BULVAR_CRON_SECRET=
BULVAR_RESEND_API_KEY=
BULVAR_DISTRIBUTION_EMAIL_FROM=
BULVAR_DISTRIBUTION_EMAIL_TO=

# === OPTIONAL: GLM-OCR (Supply Invoices) ===
# OpenAI-compatible chat/completions endpoint for GLM OCR
GLM_OCR_API_URL=
GLM_OCR_API_KEY=
GLM_OCR_MODEL=glm-4.1v-thinking-flash
GLM_OCR_CONFIDENCE_THRESHOLD=0.85

# === OPTIONAL: Security ===
# Enable strict audit mode (allowlist only for metadata keys)
# AUDIT_STRICT_MODE=true

# === OPTIONAL: Role Access (RBAC bootstrap) ===
# Comma-separated allowlist for full owner access.
# Used when user metadata role is not set yet.
OWNER_EMAILS=
OWNER_USER_IDS=


# TEMP: bootstrap role for local testing (remove after Supabase RBAC is enabled)
RBAC_DEFAULT_ROLE=
